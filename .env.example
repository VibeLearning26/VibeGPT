# ============================================================
# VibeGPT - Campus Study Agent
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=VibeGPT
DOMAIN=vibegpt.yourdomain.com
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Keep false for real FastAPI JWT authentication. Enable only for an offline UI demo.
NEXT_PUBLIC_DEMO_MODE=false

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vibegpt:vibegpt_dev_password@localhost:5432/vibegpt
POSTGRES_DB=vibegpt
POSTGRES_USER=vibegpt
POSTGRES_PASSWORD=vibegpt_dev_password

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# ── AI / LLM ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Initial Admin (created on first startup) ─────────────────
INITIAL_ADMIN_EMAIL=admin@vibegpt.local
INITIAL_ADMIN_PASSWORD=change-this-admin-password

# ── Worker ───────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=10
WORKER_MAX_RETRIES=3
