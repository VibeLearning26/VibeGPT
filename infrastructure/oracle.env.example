# Copy this file to ../.env on the Oracle VPS and replace every placeholder.
# Never commit the completed .env file.

APP_ENV=staging
APP_NAME=VibeGPT
DOMAIN=YOUR_VPS_PUBLIC_IP
WEB_URL=http://YOUR_VPS_PUBLIC_IP:3000
API_URL=http://YOUR_VPS_PUBLIC_IP:8000
PUBLIC_WEB_URL=http://YOUR_VPS_PUBLIC_IP:3000
PUBLIC_API_URL=http://YOUR_VPS_PUBLIC_IP:8000
CORS_ORIGINS=http://YOUR_VPS_PUBLIC_IP:3000

# Supabase Dashboard -> Connect -> Session pooler (port 5432).
# URL-encode special characters in the password.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@POOLER_HOST:5432/postgres?ssl=require

STORAGE_BACKEND=supabase
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
MAX_UPLOAD_SIZE_MB=20

JWT_SECRET_KEY=GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_64_CHARACTERS
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHOOSE_A_STRONG_ADMIN_PASSWORD

OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_DISTANCE_THRESHOLD=0.8
RAG_MIN_SOURCES=1

WORKER_POLL_INTERVAL_SECONDS=10
WORKER_MAX_RETRIES=3
